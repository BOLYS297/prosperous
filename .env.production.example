# =====================================================================
#  Modèle de configuration PRODUCTION
#  -> à copier en ".env" sur le VPS, puis compléter les valeurs.
#  Ce fichier sert à la fois à Laravel ET à docker-compose.
# =====================================================================

APP_NAME="Prosperous Motos"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://votre-domaine.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- Base de données (le HOST doit être "db" = nom du service docker) ---
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=prosperous
DB_USERNAME=prosperous
DB_PASSWORD=changez_ce_mot_de_passe
# Mot de passe root MySQL (utilisé uniquement par docker-compose) :
DB_ROOT_PASSWORD=changez_ce_mot_de_passe_root

# --- Drivers (database = aucun service supplémentaire requis) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- E-mail (exemple SMTP ; adaptez à votre fournisseur) ---
MAIL_MAILER=smtp
MAIL_HOST=smtp.votre-fournisseur.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="no-reply@votre-domaine.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# =====================================================================
#  Variables utilisées par docker-compose / Caddy (HTTPS)
# =====================================================================
APP_DOMAIN=votre-domaine.com
ACME_EMAIL=vous@votre-domaine.com
